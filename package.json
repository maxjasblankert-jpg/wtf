{
  "name": "catan-cities-and-knights",
  "version": "1.0.0",
  "description": "Multiplayer digital implementation of Catan: Cities & Knights",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:bridge": "tsx server/bridge.ts",
    "build": "npm run build:client",
    "build:client": "vite build client",
    "test": "vitest run"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.3",
    "express": "^4.19.2",
    "firebase": "^12.15.0",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.6.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vite": "^5.2.13",
    "vitest": "^1.6.0"
  }
}
